        { "lang": "ph3", "sig": "BossScene::GetEnemyBossSceneObjectID()", "type": "int-(boss-scene-object-id)", "doc": "Gets the boss scene object ID.\nWhen not in a boss scene, returns ID_INVALID." },
        { "lang": "ph3", "sig": "Enemy::GetEnemyBossObjectID()", "type": "int[]-(enemy-object-id)", "doc": "Gets the ID of the boss present on the screen, and returns it in an array." },
        { "lang": "ph3", "sig": "Enemy::GetAllEnemyID()", "type": "int[]-(enemy-object-id)", "doc": "Gets the ID of every enemy present on the screen, and returns them in an array." },
        { "lang": "ph3", "sig": "Enemy::GetIntersectionRegistedEnemyID()", "type": "int[]-(enemy-object-id)", "doc": "Gets the Object ID of all enemies with a registered hitbox to player shots (via ObjEnemy_SetIntersectionCircleToShot())." },
        { "lang": "ph3", "sig": "Enemy::GetAllEnemyIntersectionPosition()", "type": "float[][2]", "doc": "Gets the the position of all enemies for which collision detection is true (currently intersecting)\nReturns it in a 2-dimension array ([index][x-coordinate, y-coordinate])." },
        { "lang": "ph3", "sig": "Enemy::GetEnemyIntersectionPosition(x, y, maxPositions)", "type": "real real int float[][2]", "doc": "Gets the enemy intersection position around given position, and returns a 2D array ([index][x-coordinate, y-coordinate])\nThe first value (index 0) corresponds to the nearest position." },
        { "lang": "ph3", "sig": "Enemy::GetEnemyIntersectionPositionByIdA1(obj)", "type": "int float[][2]", "doc": "Gets all collision detection positions of the specified enemy, and returns a 2D array ([index][x-coordinate, y-coordinate])." },
        { "lang": "ph3", "sig": "Enemy::GetEnemyIntersectionPositionByIdA2(obj, x, y)", "type": "int real real float[][2]", "doc": "Gets all collision detection positions of the specified enemy, and returns a 2D array ([index][x-coordinate, y-coordinate]).\nThe first value (index 0) corresponds to the nearest position from the specified position." },
        { "lang": "ph3", "sig": "Enemy::LoadEnemyShotData(path)", "type": "string void", "doc": "Loads specified shot image file.\nFiles with the same name can only be loaded once." },
        { "lang": "ph3", "sig": "Enemy::ReloadEnemyShotData(path)", "type": "string void", "doc": "Reloads specified shot image file (you can also (re)load a file that has not been loaded by LoadEnemyShotData).\nUnlike LoadEnemyShotData, this function can load the same file several times." },

        // Shot functions

        { "lang": "ph3", "sig": "Shot::DeleteShotAll(bulletType, deleteType)", "type": "const-int const-int void", "doc": "Deletes all shot objects on screen matching the criteria, utilizing the selected deletion type.\nshottype can be:\nTYPE_ALL (all shot objects)\nTYPE_SHOT (shot objects without spell resistance)\nTYPE_CHILD (shot objects fired from the currently running script)\ndeletetype can be:\nTYPE_IMMEDIATE (immediately delete the bullets)\nTYPE_FADE (slowly fade out the bullets)\nTYPE_ITEM (turn the bullets into items according to the running item script)\nNote: With TYPE_FADE, bullets will still be visible while fading out, but they will not have any collision." },
        { "lang": "ph3", "sig": "Shot::DeleteShotInCircle(bulletType, deleteType, x, y, radius)", "type": "const-int const-int real real real void", "doc": "Deletes all shot objects matching the criteria in the designated circle centered at (xcoord, ycoord) with provided radius, utilizing the selected deletion type.\nshottype can be:\nTYPE_ALL (all shot objects)\nTYPE_SHOT (shot objects without spell resistance)\nTYPE_CHILD (shot objects fired from the currently running script)\ndeletetype can be:\nTYPE_IMMEDIATE (immediately delete the bullets)\nTYPE_FADE (slowly fade out the bullets)\nTYPE_ITEM (turn the bullets into items according to the running item script)\nNote: With TYPE_FADE, bullets will still be visible while fading out, but they will not have any collision." },
        { "lang": "ph3", "sig": "Shot::CreateShotA1(x, y, speed, angle, graphic, delay)", "type": "real real real real const-int int int-(shot-object-id)", "doc": "Creates a basic bullet that will move in the angle and speed defined.\nGraphic is the image the bullet will have, while delay is the time in frames that the bullet will appear.\nDuring its delay, there will be a cloud that appears where the bullet will spawn.\nReturns a void value in a player script if the player is unable to shoot." },
        { "lang": "ph3", "sig": "Shot::CreateShotA2(x, y, speed, angle, accel, maxSpeed, graphic, delay)", "type": "real real real real real real const-int int int-(shot-object-id)", "doc": "Same as CreateShotA1, except you can define an acceleration and max speed for the bullet.\nThe number defined for acceleration will be applied to the bullet per frame, so this will usually have low numbers such as 0.1.\nNegative values may be used, however, having a negative value on acceleration but a positive number on max speed (or vice versa) will result in the bullet spawning at max speed.\nGraphic is the image the bullet will have, while delay is the time in frames that the bullet will appear.\nDuring its delay, there will be a cloud that appears where the bullet will spawn.\nReturns a void value in a player script if the player is unable to shoot." },
        { "lang": "ph3", "sig": "Shot::CreateShotOA1(obj, speed, angle, graphic, delay)", "type": "int-(move-object-id) real real const-int int int-(shot-object-id)", "doc": "Creates a bullet that will spawn on the coordinates of the given object id.\nThe bullet and its parameters act the same as CreateShotA1.\nGraphic is the image the bullet will have, while delay is the time in frames that the bullet will appear.\nDuring its delay, there will be a cloud that appears where the bullet will spawn.\nReturns a void value in a player script if the player is unable to shoot." },
        { "lang": "ph3", "sig": "Shot::CreateShotB1(x, y, speedX, speedY, graphic, delay)", "type": "real real real real const-int int int-(shot-object-id)", "doc": "Creates a bullet that will move at the specified x and y speeds.\nGraphic is the image the bullet will have, while delay is the time in frames that the bullet will appear.\nDuring its delay, there will be a cloud that appears where the bullet will spawn.\nReturns a void value in a player script if the player is unable to shoot." },
        { "lang": "ph3", "sig": "Shot::CreateShotB2(x, y, speedX, speedY, accelX, accelY, maxSpeedX, maxSpeedY, graphic, delay)", "type": "real real real real real real real real const-int int int-(shot-object-id)", "doc": "Creates a bullet that will move at the specified x and y speeds, incrementing its speed components by the respective acceleration component every frame, capping at the maxspeed for each component.\nGraphic is the image the bullet will have, while delay is the time in frames that the bullet will appear.\nDuring its delay, there will be a cloud that appears where the bullet will spawn.\nReturns a void value in a player script if the player is unable to shoot." },
        { "lang": "ph3", "sig": "Shot::CreateShotOB1(obj, speedX, speedY, graphic, delay)", "type": "int-(move-object-id) real real const-int int int-(shot-object-id)", "doc": "Creates a bullet that will spawn on the coordinates of the given object id and will move at the specified x and y speeds.\nThe bullet and its parameters act the same as CreateShotB1.\nGraphic is the image the bullet will have, while delay is the time in frames that the bullet will appear.\nDuring its delay, there will be a cloud that appears where the bullet will spawn.\nReturns a void value in a player script if the player is unable to shoot." },
        { "lang": "ph3", "sig": "Shot::CreateLooseLaserA1(x, y, speed, angle, length, width, graphic, delay)", "type": "real real real real real real const-int int int-(shot-object-id)", "doc": "Creates a loose (moving) laser that will move at the angle and speed defined, with its size defined by the length (in direction of travel) and width.\nGraphic is the image the laser will have, while delay is the time in frames that the laser will appear.\nDuring its delay, there will be a cloud that appears where the laser will spawn.\nReturns a void value in a player script if the player is unable to shoot.\nThis function can be used to create larger bullets." },
        { "lang": "ph3", "sig": "Shot::CreateStraightLaserA1(x, y, angle, length, width, deleteTime, graphic, delay)", "type": "real real real real real int const-int int int-(shot-object-id)", "doc": "Creates a straight laser mounted at the position provided, with its size defined by the length (in direction of travel) and width.\nGraphic is the image the laser will have, while delay is the time in frames that the laser will appear.\nThe 'deletetime' argument determines how many frames until the laser disappears.\nDuring the delay, the laser will appear as a very thin laser that has no collision (aka delay laser) in order to give the player a warning.\nHaving no delay while using this function is not advisable, as the laser will spawn at full size the moment the delay is over.\nReturns a void value in a player script if the player is unable to shoot." },
        { "lang": "ph3", "sig": "Shot::CreateCurveLaserA1(x, y, speed, angle, length, width, graphic, delay)", "type": "real real real real real real const-int int int-(shot-object-id)", "doc": "Creates a curve laser that will move at the angle and speed defined, with its size defined by the length (in direction of travel) and width.\nGraphic is the image the laser will have, while delay is the time in frames that the laser will appear.\nDuring its delay, there will be a cloud that appears where the laser will spawn.\nReturns a void value in a player script if the player is unable to shoot.\nUse ObjMove_SetAngularVelocity to adjust the curve of this laser.\nThis function is heavy to process, so having many curve lasers on-screen at the same time is not recommended." },
        { "lang": "ph3", "sig": "Shot::SetShotIntersectionCircle(x, y, radius)", "type": "real real real void", "doc": "Adds a circular player hitbox at the specified position with the provided radius.\nLasts one frame." },
        { "lang": "ph3", "sig": "Shot::SetShotIntersectionLine(startX, startY, endX, endY, width)", "type": "real real real real real void", "doc": "Adds a linear player hitbox between the two specified positions with the provided width.\nLasts one frame." },
        { "lang": "ph3", "sig": "Shot::GetShotIdInCircleA1(x, y, radius)", "type": "real real real int[]-(shot-object-id)", "doc": "Returns the object IDs of the bullets inside the given circle in an array.\nInside a player script, it will only return enemy bullet IDs, and vice versa." },
        { "lang": "ph3", "sig": "Shot::GetShotIdInCircleA2(x, y, radius, target)", "type": "real real real const-int int[]-(shot-object-id)", "doc": "Returns the object IDs of the bullets inside the given circle with the specified target type in an array.\nTARGET_ALL: all shots. TARGET_ENEMY: enemy shots only. TARGET_PLAYER: player shots only.\nInside a player script, it will only return enemy bullet IDs, and vice versa." },
        { "lang": "ph3", "sig": "Shot::GetShotCount(target)", "type": "const-int int", "doc": "Returns the number of bullets with the specified target type.\nTARGET_ALL: all shots. TARGET_ENEMY: enemy shots only. TARGET_PLAYER: player shots only." },
        { "lang": "ph3", "sig": "Shot::SetShotAutoDeleteClip(left, top, right, bottom)", "type": "int int int int void", "doc": "Sets at what point bullets will be automatically deleted when leaving the STG screen.\nTo override this auto-deletion, use ObjShot_SetAutoDelete on the bullet you want to prevent from auto-deleting.\nDefault is (64, 64, 64, 64)." },
        { "lang": "ph3", "sig": "Shot::GetShotDataInfoA1(graphic, target, info)", "type": "const-int const-int const-int any", "doc": "Returns information from the shotsheet depending on the information requested.\nTarget shot sheet can be TARGET_PLAYER or TARGET_ENEMY.\nInfo type can be:\nINFO_RECT (returns [left, top, right, bottom] for the graphic)\nINFO_DELAY_COLOR (returns [red, green, blue] for the graphic)\nINFO_BLEND (returns blend type for the graphic)\nINFO_COLLISION (returns radius of collision detection)\nINFO_COLLISION_LIST (returns 2D array of collision hitbox radii and coordinates [radius, x, y])"},
        { "lang": "ph3", "sig": "Shot::StartShotScript(path)", "type": "string void", "doc": "Starts the specified shot script." },

        // Item functions

        { "lang": "ph3", "sig": "Item::CreateItemA1(itemType, x, y, score)", "type": "const-int real real int int-(item-object-id)", "doc": "Creates an item at the specified points. The types ending in _S will create a smaller version of the specified item.\nScore is the value the spawned item will add to your score.\nTypes:\nITEM_1UP\nITEM_1UP_S\nITEM_SPELL\nITEM_SPELL_S\nITEM_POINT\nITEM_POINT_S\nITEM_POWER\nITEM_POWER_S\nITEM_USER" },
        { "lang": "ph3", "sig": "Item::CreateItemA2(itemType, x, y, destX, destY, score)", "type": "const-int real real real real int int-(item-object-id)", "doc": "Same as CreateItemA1, except now it will quickly move towards the specified coordinates before slowly falling down.\nTypes:\nITEM_1UP\nITEM_1UP_S\nITEM_SPELL\nITEM_SPELL_S\nITEM_POINT\nITEM_POINT_S\nITEM_POWER\nITEM_POWER_S\nITEM_USER" },
        { "lang": "ph3", "sig": "Item::CreateItemU1(id, x, y, score)", "type": "const-int real real int int-(item-object-id)", "doc": "Creates an item much like CreateItemA1, however it will spawn a user-defined item associated with the specified ID." },
        { "lang": "ph3", "sig": "Item::CreateItemU2(id, x, y, destX, destY, score)", "type": "const-int real real real real int int-(item-object-id)", "doc": "Creates an item much like CreateItemA2, however it will spawn a user-defined item associated with the specified ID." },
        { "lang": "ph3", "sig": "Item::CollectAllItems()", "type": "void", "doc": "Makes all items fly towards the player" },
        // Removed CollectItemsByType
