        // Player Main Functions

        { "lang": "ph3", "sig": "Player::CreatePlayerShotA1(x, y, speed, angle, damage, penetration, graphic)", "type": "real real real real real int const-int int-(shot-object-id)", "doc": "Fires a player shot with the specified position, speed, angle, damage, penetration, and graphic ID from the player shotsheet.\nIf the player is not permitted to shoot, then this function returns void." },
        { "lang": "ph3", "sig": "Player::CallSpell()", "type": "void", "doc": "If the conditions to use a spell card are met, uses a spell card.\nIf the player is not permitted to shoot, then this function returns void." },
        { "lang": "ph3", "sig": "Player::LoadPlayerShotData(path)", "type": "string void", "doc": "Loads the shot data image file, allowing usage of the specified shot IDs within the player script.\nIf called several times, loads each file in succession as long as the IDs are different.\nA file cannot be loaded multiple times in a row." },
        { "lang": "ph3", "sig": "Player::ReloadPlayerShotData(path)", "type": "string void", "doc": "Reloads the shot data image file, allowing usage of the specified shot IDs within the player script.\nA file can be loaded several times with this function.\nCan be used without loading through LoadPlayerShotData first." },
        { "lang": "ph3", "sig": "Player::GetSpellManageObject()", "type": "int[]-(spell-object-id)", "doc": "Returns an array of spell card management object IDs.\nAt the end of the spell card you need to delete this object with ObjDelete." },

