        { "lang": "ph3", "sig": "Player::ObjSpell_SetIntersectionLine(obj, startX, startY, endX, endY, width)", "type": "int-(spell-object-id) real real real real real void", "doc": "Sets the collision line of the spell object associated with objID." },

