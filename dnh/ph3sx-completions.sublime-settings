        { "lang": "ph3", "sig": "Move::ObjMove_SetDestAtWeight(obj, x, y, weight, max_s)", "type": "int-(move-object-id) real real real real void", "doc": "Moves the object towards the given coordinates. It will slow down near the end of the movement based on the weight specified." },
        { "lang": "ph3", "sig": "Move::ObjMove_AddPatternA1(obj, frame, speed, angle)", "type": "int-(move-object-id) int real real void", "doc": "After the specified number of frames, changes the speed and angle of the object. NO_CHANGE can be used to preserve the original speed or angle." },
        { "lang": "ph3", "sig": "Move::ObjMove_AddPatternA2(obj, frame, speed, angle, accel, wVel, maxSpeed)", "type": "int-(move-object-id) int real real real real real void", "doc": "After the specified number of frames, changes the movement properties of the object. NO_CHANGE can be used to preserve the original properties." },
        { "lang": "ph3", "sig": "Move::ObjMove_AddPatternA3(obj, frame, speed, angle, accel, wVel, maxSpeed, graphic)", "type": "int-(move-object-id) int real real real real real const-int void", "doc": "After the specified number of frames, changes the movement properties of the object. NO_CHANGE can be used to preserve the original properties." },
        { "lang": "ph3", "sig": "Move::ObjMove_AddPatternA4(obj, frame, speed, angle, accel, wVel, maxSpeed, objDest, graphic)", "type": "int-(move-object-id) int real real real real real int-(move-object-id) const-int void", "doc": "After the specified number of frames, changes the movement properties of the object. NO_CHANGE can be used to preserve the original properties.\nThe angle parameter is relative to the angle from the object to the target.\nFor instance, if the player object id is used as the target, an angle of 0 will cause the object to aim for the player." },
        { "lang": "ph3", "sig": "Move::ObjMove_AddPatternB1(obj, frame, speedX, speedY)", "type": "int-(move-object-id) int real real void", "doc": "After the specified number of frames, changes the x and y movement speeds of the object. NO_CHANGE can be used to preserve the original speeds." },
        { "lang": "ph3", "sig": "Move::ObjMove_AddPatternB2(obj, frame, speedX, speedY, accelX, accelY, maxSpeedX, maxSpeedY)", "type": "int-(move-object-id) int real real real real real real void", "doc": "After the specified number of frames, changes the movement properties of the object. NO_CHANGE can be used to preserve the original properties." },
        { "lang": "ph3", "sig": "Move::ObjMove_AddPatternB3(obj, frame, speedX, speedY, accelX, accelY, maxSpeedX, maxSpeedY, graphic)", "type": "int-(move-object-id) int real real real real real real const-int void", "doc": "After the specified number of frames, changes the movement properties of the object. NO_CHANGE can be used to preserve the original properties." },
