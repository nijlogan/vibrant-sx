        { "lang": "ph3sx", "sig": "Math::Interpolate_Linear(a, b, x)", "type": "real real real float", "doc": "Returns the result of interpolation between a and b, using x as the interpolation value.\nInterpolation method is linear.\nDirect formula is (a + (b - a) * (x))\nRepresented by the red graph.\nWhen interpolating between two arrays, they must be of the same size." },
        { "lang": "ph3sx", "sig": "Math::Interpolate_Smooth(a, b, x)", "type": "real real real float", "doc": "Returns the result of interpolation between a and b, using x as the interpolation value.\nInterpolation method is first-order smoothstep curve.\nDirect formula is (a + (b - a) * (x^2 * (3 - 2 * x)))\nRepresented by the blue graph.\nWhen interpolating between two arrays, they must be of the same size." },
        { "lang": "ph3sx", "sig": "Math::Interpolate_Smoother(a, b, x)", "type": "real real real float", "doc": "Returns the result of interpolation between a and b, using x as the interpolation value.\nInterpolation method is second-order smoothstep curve.\nDirect formula is (a + (b - a) * (x^3 * (x * (x * 6 - 15) + 10)))\nRepresented by the green graph.\nWhen interpolating between two arrays, they must be of the same size." },
        { "lang": "ph3sx", "sig": "Math::Interpolate_Accelerate(a, b, x)", "type": "real real real float", "doc": "Returns the result of interpolation between a and b, using x as the interpolation value.\nInterpolation method is parabolic.\nDirect formula is (a + (b - a) * (x^2))\nRepresented by the purple graph.\nWhen interpolating between two arrays, they must be of the same size." },
        { "lang": "ph3sx", "sig": "Math::Interpolate_Decelerate(a, b, x)", "type": "real real real float", "doc": "Returns the result of interpolation between a and b, using x as the interpolation value.\nInterpolation method is inverse parabolic.\nDirect formula is (a + (b - a) * (1 - (1 - x)^2))\nRepresented by the black graph.\nWhen interpolating between two arrays, they must be of the same size." },
        { "lang": "ph3sx", "sig": "Math::Interpolate_Modulate(a, b, c, x)", "type": "real real real real float", "doc": "Returns the result of interpolation between a and b, using x as the interpolation value.\nInterpolation method is sine.\nDirect formula is (a + (b - a) * (x + (rsin(2pi * x) / (2pi)) * c))\nRepresented by the dotted red graph." },
        { "lang": "ph3sx", "sig": "Math::Interpolate_Overshoot(a, b, c, x)", "type": "real real real real float", "doc": "Returns the result of interpolation between a and b, using x as the interpolation value.\nInterpolation method is half sine.\nDirect formula is (a + (b - a) * (x + (rsin(pi * x) / pi) * c))\nRepresented by the dotted blue graph." },
        { "lang": "ph3sx", "sig": "Math::Interpolate_QuadraticBezier(a, b, c, x)", "type": "real real real real float", "doc": "Calculates a coordinate component of a quadratic Bezier curve.\nDirect formula is ((a * (1 - x)^2) + (2 * c * x * (1 - x)) + (b * x^2))\nRepresented by the red graph." },
        { "lang": "ph3sx", "sig": "Math::Interpolate_CubicBezier(a, b, c1, c2, x)", "type": "real real real real real float", "doc": "Calculates a coordinate component of a cubic Bezier curve.\nDirect formula is ((a * (1 - x)^3) + (3 * c1 * x * (1 - x)^2) + (3 * c2 * x^2 * (1 - x)) + (b * x^3))\nRepresented by the blue graph." },
        { "lang": "ph3sx", "sig": "Math::Interpolate_Hermite(startX, startY, endX, endY, startMagnitude, startAngle, endMagnitude, endAngle, x)", "type": "real real real real real real real real real float[2]", "doc": "Calculates the position along the given cubic Hermite spline curve." },
        { "lang": "ph3sx", "sig": "Math::Interpolate_X(a, b, x, interpolationType)", "type": "real real real const-int float", "doc": "Interpolates between a and b using x with the given interpolation type.\nAvailable interpolation types:\nLERP_LINEAR: Interpolate_Linear\nLERP_SMOOTH: Interpolate_Smooth\nLERP_SMOOTHER: Interpolate_Smoother\nLERP_ACCELERATE: Interpolate_Accelerate\nLERP_DECELERATE: Interpolate_Decelerate" },
        { "lang": "ph3sx", "sig": "Math::Interpolate_X_PackedInt(a, b, x, interpolationType)", "type": "int int real const-int int", "doc": "Divides a and b (both 8-byte ints) into eight 1-byte chunks, performs interpolation on each pair, and recombines them to return the result." },
        { "lang": "ph3sx", "sig": "Math::Interpolate_X_Angle(a, b, x, interpolationType)", "type": "real real real const-int float", "doc": "Interpolates between angles a and b using x with the given interpolation type.\nEquivalent to:\nNormalizeAngle(a + Interpolate_X(0, AngularDistance(a, b), x, type));" },
        { "lang": "ph3sx", "sig": "Math::Interpolate_X_AngleR(a, b, x, interpolationType)", "type": "real real real const-int float", "doc": "Interpolates between angles a and b using x with the given interpolation type.\nEquivalent to:\nNormalizeAngleR(a + Interpolate_X(0, AngularDistanceR(a, b), x, type));" },
        { "lang": "ph3sx", "sig": "Math::Interpolate_X_Array(array, x, interpolationType)", "type": "real[] real const-int float", "doc": "Interpolates between multiple elements of the array." },
        
