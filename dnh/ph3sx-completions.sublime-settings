        { "lang": "ph3sx-zlabel", "sig": "Spline::ObjSpline_AddNode(obj, x, y, tangentX, tangentY)", "type": "int-(spline-object-id) float float float float void", "doc": "Adds a node to the spline object with the values (posX, posY, 0, velX, velY, 0)." },
        { "lang": "ph3sx-zlabel", "sig": "Spline::ObjSpline_AddNode(obj, x, y, z, tangentX, tangentY, tangentZ)", "type": "int-(spline-object-id) float float float float float float void", "doc": "Adds a node to the spline object with the values (posX, posY, posZ, velX, velY, velZ)." },
        { "lang": "ph3sx-zlabel", "sig": "Spline::ObjSpline_SetNode(obj, index, x, y, z, tangentX, tangentY, tangentZ)", "type": "int-(spline-object-id) int float float float float float float void", "doc": "Sets the node at the specified index in the spline object to the values specified." },
        { "lang": "ph3sx-zlabel", "sig": "Spline::ObjSpline_GetNode(obj, index)", "type": "int-(spline-object-id) int float[6]", "doc": "Returns the node at the specified index in the spline object, formatted as [posX, posY, posZ, velX, velY, velZ]." },
        { "lang": "ph3sx-zlabel", "sig": "Spline::ObjSpline_GetNodeCount(obj)", "type": "int-(spline-object-id) int", "doc": "Returns the node count of the spline object." },
        { "lang": "ph3sx-zlabel", "sig": "Spline::ObjSpline_GetArcLength(obj, fraction)", "type": "int-(spline-object-id) float float", "doc": "Returns the arc length of the spline object when traversing it by the fraction.\nWhen fraction = 1, the value returned is that of the whole spline." },
        { "lang": "ph3sx-zlabel", "sig": "Spline::ObjSpline_Align(obj)", "type": "int-(spline-object-id) void", "doc": "Performs Catmull-Rom initialization of the spline object, creating a smooth and optimal path between nodes." },
        { "lang": "ph3sx-zlabel", "sig": "Spline::ObjSpline_Lerp(obj, fraction)", "type": "int-(spline-object-id) float float[6]", "doc": "Returns the position and tangent of spline object when linearly interpolating along it by the fraction.\nUse this one if you want dynamic speed of traversal (slow around bends, fast along straights) along the spline.\nReturn value is formatted as [posX, posY, posZ, velX, velY, velZ]." },
        { "lang": "ph3sx-zlabel", "sig": "Spline::ObjSpline_LerpArc(obj, fraction)", "type": "int-(spline-object-id) float float[6]", "doc": "Returns the position and tangent of spline object when linearly interpolating along its arc length by the fraction.\nUse this one if you want constant speed of traversal along the spline.\nReturn value is formatted as [posX, posY, posZ, velX, velY, velZ]." },

        { "lang": "ph3sx-zlabel", "sig": "Spring::ObjSpring_Create()", "type": "int-(spring-object-id)", "doc": "Creates a spring object and returns its object ID.\nCan be used to simulate a spring mass system in both 2D and 3D." },
        { "lang": "ph3sx-zlabel", "sig": "Spring::ObjSpring_Step(obj)", "type": "int-(spring-object-id) void", "doc": "Simulates the spring mass system for one step of delta time.\nTo simulate the system in real time, call this function once every frame." },
        { "lang": "ph3sx-zlabel", "sig": "Spring::ObjSpring_SetGravity(obj, gravity)", "type": "int-(spring-object-id) float void", "doc": "Sets the global gravity value for the spring mass system." },
        { "lang": "ph3sx-zlabel", "sig": "Spring::ObjSpring_SetGlobalDrag(obj, drag)", "type": "int-(spring-object-id) float void", "doc": "Sets the global drag coefficient for the spring mass system." },
        { "lang": "ph3sx-zlabel", "sig": "Spring::ObjSpring_AddNode(obj, x, y, z, velX, velY, velZ, mass, canMove)", "type": "int-(spring-object-id) float float float float float float float bool void", "doc": "Adds a node to the spring object with the values specified.\nThe flag \"canMove\" when set to false will lock the node in place, and it can only be moved manually." },
        { "lang": "ph3sx-zlabel", "sig": "Spring::ObjSpring_SetNode(obj, nodeIndex, x, y, z, velX, velY, velZ, mass, canMove)", "type": "int-(spring-object-id) int float float float float float float float bool void", "doc": "Sets the node at the specified index in the spring object to the values specified." },
        { "lang": "ph3sx-zlabel", "sig": "Spring::ObjSpring_GetNode(obj, nodeIndex)", "type": "int-(spring-object-id) int float[7]", "doc": "Returns the node at the specified index in the spring object, formatted as [posX, posY, posZ, velX, velY, velZ, mass]." },
        { "lang": "ph3sx-zlabel", "sig": "Spring::ObjSpring_RemoveNode(obj, nodeIndex)", "type": "int-(spring-object-id) int void", "doc": "Removes the node at the specified index from the spring object.\nAny springs that contained this node at one of their ends will also be removed." },
        { "lang": "ph3sx-zlabel", "sig": "Spring::ObjSpring_AddSpring(obj, nodeIndex1, nodeIndex2, ks, kd, restLength)", "type": "int-(spring-object-id) int int float float float void", "doc": "Adds a spring to the spring object, attaching the two nodes specified by arguments 2 and 3.\nThe values ks and kd correspond to the magnitude of the force the spring applies to the two nodes, where ks is used to bring the distance of the two nodes back to the rest length, and kd is the drag." },
        { "lang": "ph3sx-zlabel", "sig": "Spring::ObjSpring_SetSpring(obj, springIndex, nodeIndex1, nodeIndex2, ks, kd, restLength)", "type": "int-(spring-object-id) int int int float float float void", "doc": "Sets the spring at the specified index in the spring object to the values specified." },
        { "lang": "ph3sx-zlabel", "sig": "Spring::ObjSpring_GetSpring(obj, springIndex)", "type": "int-(spring-object-id) int float[5]", "doc": "Returns the spring at the specified index in the spring object, formatted as [node1, node2, ks, kd, restLength]." },
        { "lang": "ph3sx-zlabel", "sig": "Spring::ObjSpring_RemoveSpring(obj, springIndex)", "type": "int-(spring-object-id) int void", "doc": "Removes the spring at the specified index from the spring object.\nThe two nodes that were connected by the spring will still remain." },
        { "lang": "ph3sx-zlabel", "sig": "Spring::ObjSpring_AddPlane(obj, x, y, z, normalX, normalY, normalZ, ks, kd, epsilon)", "type": "int-(spring-object-id) float float float float float float float float float void", "doc": "Adds a plane to the spring object, creating a collision boundary that will affect all nodes in the spring object.\nThe values normalX/Y/Z correspond to the normal of the plane (doesn't have to be normalized).\nThe value epsilon corresponds to the distance a node must be away from the plane before it will start colliding.\nHigher values of epsilon mean collision will occur farther away from the plane surface.\nCollsion is handled using penalty forces, meaning sufficiently low values of ks and kd will allow nodes to breach planes.\nFor more elastic collision, use low ks. For more rigid collision, use high ks." },
        { "lang": "ph3sx-zlabel", "sig": "Spring::ObjSpring_SetPlane(obj, planeIndex, x, y, z, normalX, normalY, normalZ)", "type": "int-(spring-object-id) int float float float float float float void", "doc": "Sets the plane in the spring object to the specified values." },
        { "lang": "ph3sx-zlabel", "sig": "Spring::ObjSpring_SetPlane(obj, planeIndex, x, y, z, normalX, normalY, normalZ, ks, kd, epsilon)", "type": "int-(spring-object-id) int float float float float float float float float float void", "doc": "Sets the plane in the spring object to the specified values." },
        { "lang": "ph3sx-zlabel", "sig": "Spring::ObjSpring_GetPlane(obj, planeIndex)", "type": "int-(spring-object-id) int float[9]", "doc": "Returns the plane at the specified index in the spring object, formatted as [x, y, z, normalX, normalY, normalZ, ks, kd, epsilon]." },
        { "lang": "ph3sx-zlabel", "sig": "Spring::ObjSpring_RemovePlane(obj, planeIndex)", "type": "int-(spring-object-id) int void", "doc": "Removes the plane at the specified index from the spring object." },

