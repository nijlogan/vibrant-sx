        // Custom Script Functions

        { "lang": "ph3", "sig": "Shot::SetShotDeleteEventEnable(eventType, register)", "type": "const-int bool void", "doc": "Sets whether the bullet deletion event is allowed to occur.\nEvent types are:\nEV_DELETE_SHOT_IMMEDIATE (event will delete the shot immediately)\nEV_DELETE_SHOT_FADE (event will fade out the shot)\nDefault is false for both event types." },

        // Package Functions

        { "lang": "ph3", "sig": "Package::ClosePackage()", "type": "void", "doc": "Ends the package script." },
        { "lang": "ph3", "sig": "Package::IntializeStageScene()", "type": "void", "doc": "Performs the initial processing for the stage script.\nCalled only once before the start of a stage script." },
        { "lang": "ph3", "sig": "Package::FinalizeStageScene()", "type": "void", "doc": "Terminates processing of the stage script.\nCalled only once at the end of a stage script.\nDefines the end point of replays.\nThrows an error if the stage script is not yet closed." },
        { "lang": "ph3", "sig": "Package::StartStageScene()", "type": "void", "doc": "Starts the stage script." },
        { "lang": "ph3", "sig": "Package::SetStageIndex(index)", "type": "int void", "doc": "Defines the index of the stage to be started next.\nThe value does not need to be sequential.\nSpecifying an already specified index results in an error." },
        { "lang": "ph3", "sig": "Package::SetStageMainScript(path)", "type": "string void", "doc": "Defines the stage script to be started next." },
        { "lang": "ph3", "sig": "Package::SetStagePlayerScript(path)", "type": "string void", "doc": "Defines the player script to be used in the stage.\nThis player must have been declared in the #Player header of the package.\nIf #Player is empty, you can specify all players under /script/player/folder." },
        { "lang": "ph3", "sig": "Package::SetStageReplayFile(path)", "type": "string void", "doc": "Runs the stage script once with the replay replaying all virtual key presses (including player shots, movement, etc).\nCan only be called after InitializeStageScene.\nSince the replay file holds information for each stage, in a multi-stage replay, you can begin playback from a middle stage without having to start from the first stage." },
        { "lang": "ph3", "sig": "Package::GetStageSceneState(infoType)", "type": "const-int bool", "doc": "Returns status information about the currently running stage script.\nOnly available infotype is STAGE_STATE_FINISHED (returns true if the stage is finished)." },
        { "lang": "ph3", "sig": "Package::GetStageSceneResult()", "type": "const-int", "doc": "Returns the reason why the stage script finished.\nAvailable return values are:\nSTAGE_RESULT_CLEARED (stage was cleared)\nSTAGE_RESULT_PLAYER_DOWN (player ran out of lives)\nSTAGE_RESULT_BREAK_OFF (stage ended prematurely; was terminated by player)" },
        { "lang": "ph3", "sig": "Package::PauseStageScene(pause)", "type": "bool void", "doc": "Pauses or resumes the stage script." },
        { "lang": "ph3", "sig": "Package::TerminateStageScene()", "type": "void", "doc": "Exits out of the currently running stage script." },
        { "lang": "ph3", "sig": "Package::GetLoadFreePlayerScriptList()", "type": "string[]", "doc": "Returns a list of the player scripts available in the /script/player/ folder." },
        { "lang": "ph3", "sig": "Package::GetFreePlayerScriptCount()", "type": "int", "doc": "Returns the number of player scripts available in the /script/player/ folder." },
        { "lang": "ph3", "sig": "Package::GetFreePlayerScriptInfo(playerIndex, infoType)", "type": "int const-int", "doc": "Returns various information from the header of the player script with the given index.\nAvailable infotypes are\nINFO_SCRIPT_PATH (player script path)\nINFO_SCRIPT_ID (player script's #ID)\nINFO_SCRIPT_TITLE (player script's #Title)\nINFO_SCRIPT_TEXT (player script's #Text)\nINFO_SCRIPT_IMAGE (player script's #Image)\nINFO_SCRIPT_REPLAY_NAME (player script's #ReplayName)" },
        { "lang": "ph3", "sig": "Package::LoadReplayList()", "type": "void", "doc": "Loads the list of the available replays for the current script." },
        { "lang": "ph3", "sig": "Package::GetValidReplayIndices()", "type": "int[]", "doc": "Loads a list of indices for the current script's available replays." },
        { "lang": "ph3", "sig": "Package::IsValidReplayIndex(index)", "type": "int bool", "doc": "Returns true or false depending on the index chosen is valid to be used in GetReplayInfo." },
        { "lang": "ph3", "sig": "Package::GetReplayInfo(index, infoType)", "type": "int const-int any", "doc": "Returns various information about the replay with the given index.\nAvailable infotypes are\nREPLAY_FILE_PATH (replay file path)\nREPLAY_DATE_TIME (date and time at which the replay was saved)\nREPLAY_USER_NAME (player's name)\nREPLAY_TOTAL_SCORE (final score)\nREPLAY_FPS_AVERAGE (average framerate)\nREPLAY_PLAYER_NAME (player script name)\nREPLAY_STAGE_INDEX_LIST (list of stage indices that the replay used)\nREPLAY_STAGE_START_SCORE_LIST (List of score indices at the start of each stage (the order of the stage indices is from REPLAY_STAGE_INDEX_LIST))\nREPLAY_STAGE_LAST_SCORE_LIST (List of score indices at the end of each stage (the order of the stage indices is from REPLAY_STAGE_INDEX_LIST))\nREPLAY_COMMENT (comment set arbitrarily using SetReplayInfo)" },
        { "lang": "ph3", "sig": "Package::SetReplayInfo(infoType, value)", "type": "const-int any void", "doc": "Sets replay information.\nOnly possible infotype is REPLAY_COMMENT, which takes a string.\nIt is recommended to use delimited strings to save information that can be retrieved with SplitString." },
        { "lang": "ph3", "sig": "Package::SaveReplay(index, name)", "type": "int string void", "doc": "Saves a replay to the specified replay index." },

