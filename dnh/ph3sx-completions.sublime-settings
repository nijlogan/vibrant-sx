        { "lang": "ph3sx", "sig": "Shot::ObjShot_SetDelayGraphic(obj, graphic)", "type": "int-(shot-object-id) const-int void", "doc": "Sets the image ID of the shot object's delay cloud.\nA negative value will reset the delay cloud graphic to default." },
        { "lang": "ph3sx", "sig": "Shot::ObjShot_SetDelayScaleParameter(obj, s0, s1, s2)", "type": "int-(shot-object-id) real real real void", "doc": "Sets the properties of the shot object's delay cloud's scale.\nDELAY_DEFAULT: scale = min(S0 + delay / S2, S1)\nDELAY_LERP: scale = lerpFunction(S0, S1, delay / S2)" },
        { "lang": "ph3sx", "sig": "Shot::ObjShot_SetDelayAlphaParameter(obj, a0, a1, a2)", "type": "int-(shot-object-id) real real real void", "doc": "Sets the properties of the shot object's delay cloud's alpha.\nAlpha value range is 0 to 1.\nDELAY_DEFAULT: alpha = min(A0 + delay / A2, A1)\nDELAY_LERP: alpha = lerpFunction(A0, A1, delay / A2)" },
        { "lang": "ph3sx", "sig": "Shot::ObjShot_SetDelayMode(obj, delayMode, scaleInterpolationMode, alphaInterpolationMode)", "type": "int-(shot-object-id) const-int const-int const-int void", "doc": "Sets the properties of the shot object's delay cloud.\nAvailable delay modes:\nDELAY_DEFAULT:\nDefault Danmakufu delay.\nDELAY_LERP:\nZUN-like delay.\nAvailable delay interpolation modes:\nLERP_LINEAR:\nLinear interpolation.\nLERP_SMOOTH:\nSmooth interpolation.\nLERP_SMOOTHER:\nSmoother interpolation.\nLERP_ACCELERATE:\nAccelerating interpolation.\nLERP_DECELERATE:\nDecelerating interpolation." },
        { "lang": "ph3sx", "sig": "Shot::ObjShot_SetDelayColor(obj, hex)", "type": "int-(shot-object-id) int void", "doc": "Sets the color of the shot object's delay cloud as an ARGB hexadecimal color value.\nSet to 0 to revert to using the shot data's delay color." },
        { "lang": "ph3sx", "sig": "Shot::ObjShot_SetDelayColoringEnable(obj, enable)", "type": "int-(shot-object-id) bool void", "doc": "When set to true, enables the object color to affect the shot object's delay cloud." },
        { "lang": "ph3sx", "sig": "Shot::ObjShot_SetGrazeInvalidFrame(obj, frame)", "type": "int-(shot-object-id) int void", "doc": "Sets the shot object's graze cooldown frame.\nAfter being grazed, the shot will be put on graze cooldown, wherein it cannot be grazed for the duration.\nFor lasers, the default value is 20.\nFor normal shots, the default value is 2147483647." },
        { "lang": "ph3sx", "sig": "Shot::ObjShot_SetGrazeFrame(obj, frame)", "type": "int-(shot-object-id) int void", "doc": "Sets the shot object's graze frame.\nInternally, this value is reset to the graze invalid frame every time a graze is performed.\nThis value decreases by 1 every frame, and the shot object is eligible for a graze if it is equal to or less than 0." },
        { "lang": "ph3sx", "sig": "Shot::ObjShot_IsValidGraze(obj)", "type": "int-(shot-object-id) bool", "doc": "Returns whether the shot object is currently able to be grazed." },
        { "lang": "ph3sx", "sig": "Shot::ObjShot_SetPenetrateShotEnable(obj, enable)", "type": "int-(shot-object-id) bool void", "doc": "If set to false, the shot will not lose penetration upon collision with another enemy shot.\nIntended to be used with players shots, in tandem with ObjShot_SetEraseShot.\nDefault is true." },
        { "lang": "ph3sx", "sig": "Shot::ObjShot_SetEnemyIntersectionInvalidFrame(obj, frame)", "type": "int-(shot-object-id) int void", "doc": "Sets the enemy intersection cooldown duration in frames for the shot object." },
        { "lang": "ph3sx", "sig": "Shot::ObjShot_SetFixedAngle(obj, enable)", "type": "int-(shot-object-id) bool void", "doc": "If set to true, the shot will not visually rotate along its movement angle.\nThe default value is specified in the graphic's shot data as \"fixed_angle\", this function allows you to override that value." },
        { "lang": "ph3sx", "sig": "Shot::ObjShot_SetSpinAngularVelocity(obj, wVel)", "type": "int-(shot-object-id) real void", "doc": "The default spin speed is specified in the graphic's shot data as \"angular_velocity\", this function allows you to override that value." },
        { "lang": "ph3sx", "sig": "Shot::ObjShot_SetDelayAngularVelocity(obj, wVel)", "type": "int-(shot-object-id) real void", "doc": "Sets the Z angle spin speed of the shot's delay cloud.\nThe default delay spin speed is 0." },
        
        // Straight Laser Object functions
        
        { "lang": "ph3sx", "sig": "Shot::ObjStLaser_SetEnd(obj, enable)", "type": "int-(shot-object-id) bool void", "doc": "Sets whether a delay cloud will appear at the end of the straight laser object." },
        { "lang": "ph3sx", "sig": "Shot::ObjStLaser_SetEndGraphic(obj, graphic)", "type": "int-(shot-object-id) const-int void", "doc": "Sets the shot image ID of the straight laser object \"end\" delay cloud.\nSee: ObjShot_SetDelayGraphic" },
        { "lang": "ph3sx", "sig": "Shot::ObjStLaser_SetDelayScale(obj, source, end)", "type": "int-(shot-object-id) bool bool void", "doc": "Sets the scale multipliers of the straight laser object's delay clouds.\nThe default values are (1, 1)." },
        { "lang": "ph3sx", "sig": "Shot::ObjStLaser_SetPermitExpand(obj, enable)", "type": "int-(shot-object-id) bool void", "doc": "Sets whether the straight laser will expand after the delay period.\nIntended for use in delay lines." },
        { "lang": "ph3sx", "sig": "Shot::ObjStLaser_GetPermitExpand(obj)", "type": "int-(shot-object-id) bool", "doc": "Returns whether the straight laser is permitted to expand after the delay period." },
        
        // Curvy Laser Object functions
        
        { "lang": "ph3sx", "sig": "Shot::ObjCrLaser_SetTipCapping(obj, enable)", "type": "int-(shot-object-id) bool void", "doc": "Sets whether the curvy laser will attempt to keep its graphic's tips proportional to the upper and lower halves of its sprite.\nThe exact middle of the sprite will be stretched along the laser's body between the tips.\nCan be used to emulate PC-98-styled \"cheeto lasers\"." },
        { "lang": "ph3sx", "sig": "Shot::ObjCrLaser_GetNodePointer(obj, index)", "type": "int-(shot-object-id) int int-(node-pointer)", "doc": "Returns the pointer value of the specified node index.\nThe pointer is used in other node-related functions.\nAs node traversal is relatively expensive, it is not recommended to repeatedly use this function.\nAt each frame, the node at the laser's end is invalidated if the laser is able to move.\nUsing an invalid pointer may cause a memory access violation." },
        { "lang": "ph3sx", "sig": "Shot::ObjCrLaser_GetNodePointerList(obj)", "type": "int-(shot-object-id) int[]-(node-pointer)", "doc": "Returns a list of node pointers of the curvy laser object.\nThe pointers are used in other node-related functions.\nAt each frame, the node at the laser's end is invalidated if the laser is able to move.\nUsing an invalid pointer may cause a memory access violation." },
        { "lang": "ph3sx", "sig": "Shot::ObjCrLaser_GetNodePosition(obj, ptr)", "type": "int-(shot-object-id) int-(node-pointer) float[2]", "doc": "Returns the [x, y] position array of the specified node.\nThe node pointer is obtained with ObjCrLaser_GetNodePointer[List], do NOT pass in any other values." },
        { "lang": "ph3sx", "sig": "Shot::ObjCrLaser_GetNodeAngle(obj, ptr)", "type": "int-(shot-object-id) int-(node-pointer) float", "doc": "Returns the facing angle of the specified node.\nThe node pointer is obtained with ObjCrLaser_GetNodePointer[List], do NOT pass in any other values." },
        { "lang": "ph3sx", "sig": "Shot::ObjCrLaser_GetNodeWidthScale(obj, ptr)", "type": "int-(shot-object-id) int-(node-pointer) float", "doc": "Returns the render width scale of the specified node.\nThe node pointer is obtained with ObjCrLaser_GetNodePointer[List], do NOT pass in any other values." },
        { "lang": "ph3sx", "sig": "Shot::ObjCrLaser_GetNodeColor(obj, ptr)", "type": "int-(shot-object-id) int-(node-pointer) int[4]", "doc": "Returns the [a, r, g, b] color array of the specified node.\nThe node pointer is obtained with ObjCrLaser_GetNodePointer[List], do NOT pass in any other values." },
        { "lang": "ph3sx", "sig": "Shot::ObjCrLaser_GetNodeColorHex(obj, ptr)", "type": "int-(shot-object-id) int-(node-pointer) int", "doc": "Returns the ARGB hexadecimal color value of the specified node.\nThe node pointer is obtained with ObjCrLaser_GetNodePointer[List], do NOT pass in any other values." },
        { "lang": "ph3sx", "sig": "Shot::ObjCrLaser_SetNode(obj, ptr, x, y, angle, hex)", "type": "int-(shot-object-id) int-(node-pointer) real real real int void", "doc": "Sets the position, angle, and color of the specified node.\nThe node pointer is obtained with ObjCrLaser_GetNodePointer[List], do NOT pass in any other values." },
        { "lang": "ph3sx", "sig": "Shot::ObjCrLaser_SetNode(obj, ptr, x, y, angle, hex, scale)", "type": "int-(shot-object-id) int-(node-pointer) real real real int real void", "doc": "Additional ability to set node render width render." },
        { "lang": "ph3sx", "sig": "Shot::ObjCrLaser_SetNodePosition(obj, ptr, x, y)", "type": "int-(shot-object-id) int-(node-pointer) real real void", "doc": "Sets the position of the specified node.\nThe node pointer is obtained with ObjCrLaser_GetNodePointer[List], do NOT pass in any other values." },
        { "lang": "ph3sx", "sig": "Shot::ObjCrLaser_SetNodeAngle(obj, ptr, angle)", "type": "int-(shot-object-id) int-(node-pointer) real void", "doc": "Sets the angle of the specified node.\nThe node pointer is obtained with ObjCrLaser_GetNodePointer[List], do NOT pass in any other values." },
        { "lang": "ph3sx", "sig": "Shot::ObjCrLaser_SetNodeWidthScale(obj, ptr, scale)", "type": "int-(shot-object-id) int-(node-pointer) real void", "doc": "Sets the render width scale of the specified node.\nThe node pointer is obtained with ObjCrLaser_GetNodePointer[List], do NOT pass in any other values." },
        { "lang": "ph3sx", "sig": "Shot::ObjCrLaser_SetNodeColor(obj, ptr, hex)", "type": "int-(shot-object-id) int-(node-pointer) int void", "doc": "Sets the color of the specified node as an ARGB hexadecimal color value.\nThe node pointer is obtained with ObjCrLaser_GetNodePointer[List], do NOT pass in any other values." },
        { "lang": "ph3sx", "sig": "Shot::ObjCrLaser_AddNode(obj, x, y, angle, hex)", "type": "int-(shot-object-id) real real real int void", "doc": "Adds a laser node at the end of the curvy laser with the specified position, angle, and color." },
        { "lang": "ph3sx", "sig": "Shot::ObjCrLaser_AddNode(obj, x, y, angle, hex, scale)", "type": "int-(shot-object-id) real real real int real void", "doc": "Additional ability to specify node render width render." },
        
        // Shot Pattern Object functions
        
        { "lang": "ph3sx", "sig": "Shot::ObjPatternShot_Create()", "type": "int-(pattern-shot-object-id)", "doc": "Creates a pattern shot object and returns its object ID.\nCan be used for firing a large amount of bullets with only a few function calls, like in ZUN's ECL scripts." },
        { "lang": "ph3sx", "sig": "Shot::ObjPatternShot_Fire(obj)", "type": "int-(pattern-shot-object-id) void", "doc": "Fires the shot pattern defined by the given shot pattern object." },
        { "lang": "ph3sx", "sig": "Shot::ObjPatternShot_FireReturn(obj)", "type": "int-(pattern-shot-object-id) int[]", "doc": "Fires the shot pattern defined by the given shot pattern object and returns the IDs of the created shots in an array." },
        { "lang": "ph3sx", "sig": "Shot::ObjPatternShot_SetParentObject(obj, parent)", "type": "int-(pattern-shot-object-id) int-(move-object-id) void", "doc": "Sets the parent object of the given shot pattern object." },
        { "lang": "ph3sx", "sig": "Shot::ObjPatternShot_SetPatternType(obj, patternType)", "type": "int-(pattern-shot-object-id) const-int void", "doc": "Sets the firing pattern of the given shot pattern object.\nAvailable pattern types:\nPATTERN_FAN\nPATTERN_FAN_AIMED\nPATTERN_RING\nPATTERN_RING_AIMED\nPATTERN_ARROW\nPATTERN_ARROW_AIMED\nPATTERN_POLYGON\n- [way]: Number of polygon vertices.\n- [stack]: Number of shots per sides.\n- [angle argument]: Edge skip, should normally be 1. Other values will result in polygrams.\n- [speed argument]: No effect.\nPATTERN_POLYGON_AIMED\nPATTERN_ELLIPSE\n- [stack]: No effect.\n- [angle argument]: Angle of the ellipse. (Not of the shots)\n- [base speed]: Max speed at the ends of the primary axis.\n- [speed argument]: Max speed at the ends of the secondary axis.\nPATTERN_ELLIPSE_AIMED\nPATTERN_SCATTER_ANGLE\nPATTERN_SCATTER_SPEED\nPATTERN_SCATTER\nPATTERN_LINE\nPATTERN_ROSE\n- [way]: Number of \"petals\".\n- [stack]: Number of shots per petals." },
        { "lang": "ph3sx", "sig": "Shot::ObjPatternShot_SetShotType(obj, shotType)", "type": "int-(pattern-shot-object-id) const-int void", "doc": "Sets the shot type of the given shot pattern object.\nSupported types:\nOBJ_SHOT\nOBJ_LOOSE_LASER\nOBJ_CURVE_LASER" },
        { "lang": "ph3sx", "sig": "Shot::ObjPatternShot_SetInitialBlendMode(obj, blendType)", "type": "int-(pattern-shot-object-id) const-int void", "doc": "Sets the initial blend type of the shots.\nSee ObjRender_SetBlendType for the list of blend types." },
        { "lang": "ph3sx", "sig": "Shot::ObjPatternShot_SetShotCount(obj, way, stack)", "type": "int-(pattern-shot-object-id) int int void", "doc": "Sets the shot way and shot stack of the given shot pattern object." },
        { "lang": "ph3sx", "sig": "Shot::ObjPatternShot_SetSpeed(obj, baseSpeed, speedArg)", "type": "int-(pattern-shot-object-id) real real void", "doc": "Sets the shot speed and argument of the given shot pattern object." },
        { "lang": "ph3sx", "sig": "Shot::ObjPatternShot_SetAngle(obj, baseAngle, angleArg)", "type": "int-(pattern-shot-object-id) real real void", "doc": "Sets the shot angle and argument of the given shot pattern object." },
        { "lang": "ph3sx", "sig": "Shot::ObjPatternShot_SetBasePoint(obj, x, y)", "type": "int-(pattern-shot-object-id) real real void", "doc": "Sets the base firing position of the given shot pattern object.\nDefaults to the parent object's position if not used." },
        { "lang": "ph3sx", "sig": "Shot::ObjPatternShot_SetBasePointOffset(obj, x, y)", "type": "int-(pattern-shot-object-id) real real void", "doc": "Sets the firing position offset of the given shot pattern object from its base point." },
        { "lang": "ph3sx", "sig": "Shot::ObjPatternShot_SetBasePointOffsetCircle(obj, angle, radius)", "type": "int-(pattern-shot-object-id) real real void", "doc": "Sets the firing position offset in a circular manner of the given shot pattern object from its base point." },
        { "lang": "ph3sx", "sig": "Shot::ObjPatternShot_SetShootRadius(obj, radius)", "type": "int-(pattern-shot-object-id) real void", "doc": "Causes the shots to be fired a certain radius away from their base points." },
        { "lang": "ph3sx", "sig": "Shot::ObjPatternShot_SetDelay(obj, delay)", "type": "int-(pattern-shot-object-id) int void", "doc": "Sets the shot delay of the given shot pattern object." },
        { "lang": "ph3sx", "sig": "Shot::ObjPatternShot_SetGraphic(obj, graphic)", "type": "int-(pattern-shot-object-id) const-int void", "doc": "Sets the shot image ID of the given shot pattern object." },
        { "lang": "ph3sx", "sig": "Shot::ObjPatternShot_SetLaserParameter(obj, width, length)", "type": "int-(pattern-shot-object-id) real real void", "doc": "Sets the length and width of the given shot pattern object.\nHas no effect if the pattern is firing normal shots." },
        { "lang": "ph3sx", "sig": "Shot::ObjPatternShot_CopySettings(dest, source)", "type": "int-(pattern-shot-object-id) int-(pattern-shot-object-id) void", "doc": "Copies the settings of a shot pattern object to another." },
        { "lang": "ph3sx", "sig": "Shot::ObjPatternShot_AddTransform(obj, transformType, args..)", "type": "int-(pattern-shot-object-id) const-int any.. void", "doc": "Adds a transformation to the shot pattern object.\nTransforms arguments will be designated, in order: [arg0], [arg1], [arg2], etc...\nAvailable transformations are:\nTRANSFORM_WAIT (argc = 1)\n- Delays the next transformation for [arg0] frames.\nTRANSFORM_ADD_SPEED_ANGLE (argc = 4)\n- Waits for [arg1] frames. (Does not delay the next transformation)\n- For [arg0] frames, sets acceleration to [arg2].\n- For [arg0] frames, sets angular velocity to [arg3].\nTRANSFORM_ANGULAR_MOVE (argc = 3)\n- For [arg0] frames, sets angular velocity to [arg1].\n- Sets shot graphic \"spin\" to [arg2].\nTRANSFORM_N_DECEL_CHANGE (argc = 5)\n- For [arg1] times, decelerates/accelerates the shot to a complete halt in [arg0] frames. (See: Aunn's first spell)\n- Movement will then change depending on [arg2].\n- 0: Changes the movement angle to [arg4].\n- 1: Increments the movement angle by [arg4].\n- 2: Aims to the player with an added randomness factor of -[arg4] to [arg4].\n- 3: Aims to the player with an increment of [arg4].\n- 4: Angle becomes random.\n- 5, other: No angle change.\n- All modes sets the speed to [arg3].\n- Delay the next transformation by ([arg0] * [arg1]) frames.\nTRANSFORM_GRAPHIC_CHANGE (argc = 1)\n- Changes the shot graphic to [arg0].\nTRANSFORM_BLEND_CHANGE (argc = 1)\n- Changes the shot blend type to [arg0].\nTRANSFORM_TO_SPEED_ANGLE (argc = 3)\n- Gradually changes the shot's speed to [arg1] in [arg0] frames.\n- Gradually changes the shot's angle to [arg2] in [arg0] frames.\n- Using TOPLAYER_CHANGE will aim the shot to the player object.\n- NO_CHANGE can be used for [arg1] and [arg2].\nTRANSFORM_ADDPATTERN_A1 (argc = 3)\n- Applies [ObjMove_AddPatternA1(obj, [arg0], [arg1], [arg2])]\nTRANSFORM_ADDPATTERN_A2 (argc = 8)\n- Applies [ObjMove_AddPatternA4(obj, [arg0], [arg1], [arg2], [arg3], [arg4], [arg5], [arg6], [arg7])]\nTRANSFORM_ADDPATTERN_B1 (argc = 3)\n- Applies [ObjMove_AddPatternB1(obj, [arg0], [arg1], [arg2])]\nTRANSFORM_ADDPATTERN_B2 (argc = 8)\n- Applies [ObjMove_AddPatternB3(obj, [arg0], [arg1], [arg2], [arg3], [arg4], [arg5], [arg6], [arg7])]\nTRANSFORM_ADDPATTERN_C1 (argc = 3)\n- Applies [ObjMove_AddPatternC1(obj, [arg0], [arg1], [arg2])]\nTRANSFORM_ADDPATTERN_C2 (argc = 10)\n- Applies [ObjMove_AddPatternC3(obj, [arg0], [arg1], [arg2], [arg3], [arg4], [arg5], [arg6], [arg7], [arg8], [arg9])]" },
        { "lang": "ph3sx", "sig": "Shot::ObjPatternShot_SetTransform(obj, transformIndex, transformType, args..)", "type": "int-(pattern-shot-object-id) int const-int any.. void", "doc": "Sets transformation to the specified transform index." },
        
