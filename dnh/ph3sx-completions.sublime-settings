        // Enemy Object functions

        { "lang": "ph3", "sig": "Enemy::ObjEnemy_Create(objType)", "type": "const-int int-(enemy-object-id)", "doc": "Creates an Enemy object and returns its ID. Object types are:\n\tOBJ_ENEMY\n\tOBJ_ENEMY_BOSS\nIn order to draw the enemy object and have it listed as an existing enemy, you have to register it using ObjEnemy_Regist.\nIf you want to create a boss enemy object, you have to create a boss scene object first." },
        { "lang": "ph3", "sig": "Enemy::ObjEnemy_Regist(obj)", "type": "int-(enemy-object-id) void", "doc": "Makes the specified enemy object active." },
        { "lang": "ph3", "sig": "Enemy::ObjEnemy_GetInfo(obj, infoType)", "type": "int-(enemy-object-id) const-int any", "doc": "Returns enemy info based on the info type.\n\tINFO_LIFE: Returns the life points of the enemy (real).\n\tINFO_DAMAGE_RATE_SHOT: Returns the damage rate percentage of normal player shots set by ObjEnemy_SetDamageRate (real: 1-100)\n\tINFO_DAMAGE_RATE_SPELL: Returns the damage rate percentage of player bombs set by ObjEnemy_SetDamageRate (real: 1-100)\n\tINFO_SHOT_HIT_COUNT: Returns the amount of times the enemy was hit by player bullets in the previous frame (real)" },
        { "lang": "ph3", "sig": "Enemy::ObjEnemy_SetLife(obj, life)", "type": "int-(enemy-object-id) real void", "doc": "Sets the amount of life points for the specified enemy object." },
        { "lang": "ph3", "sig": "Enemy::ObjEnemy_AddLife(obj, life)", "type": "int-(enemy-object-id) real void", "doc": "Adds the specified amount of life points to the enemy's life." },
        { "lang": "ph3", "sig": "Enemy::ObjEnemy_SetDamageRate(obj, shotRate, bombRate)", "type": "int-(enemy-object-id) real real void", "doc": "Sets the damage rate of the player's attacks against the specified enemy.\nSetting to 0 will cause the enemy to take no damage, 100 is the default (100%) value. Values above 100 are possible." },
        { "lang": "ph3", "sig": "Enemy::ObjEnemy_SetIntersectionCircleToShot(obj, x, y, radius)", "type": "int-(enemy-object-id) real real real void", "doc": "Sets the position and size of the enemy hitbox (any attack from the player touching the circle will damage the enemy)." },
        { "lang": "ph3", "sig": "Enemy::ObjEnemy_SetIntersectionCircleToPlayer(obj, x, y, radius)", "type": "int-(enemy-object-id) real real real void", "doc": "Sets the enemy hitbox for player collision. Any collision with the circle will kill the character.\nCreates a Boss Scene object and returns its ID." },

        // Boss Scene Object functions

        { "lang": "ph3", "sig": "BossScene::ObjEnemyBossScene_Create()", "type": "int-(boss-scene-object-id)", "doc": "Creates a Boss Scene object and returns its ID." },
        { "lang": "ph3", "sig": "BossScene::ObjEnemyBossScene_Regist(obj)", "type": "int-(boss-scene-object-id) void", "doc": "Starts the specified boss scene." },
        { "lang": "ph3", "sig": "BossScene::ObjEnemyBossScene_Add(obj, phase, path)", "type": "int-(boss-scene-object-id) int string", "doc": "Adds the specified script to the boss scene at the specified phase." },
        { "lang": "ph3", "sig": "BossScene::ObjEnemyBossScene_LoadInThread(obj)", "type": "int-(boss-scene-object-id) void", "doc": "Compiles all the enemy scripts in the boss scene and initializes global variables.\nAs the length of compile time cannot be guaranteed, initialize all global variables besides constants in @Initialize." },
        { "lang": "ph3", "sig": "BossScene::ObjEnemyBossScene_GetInfo(obj, infoType)", "type": "int-(boss-scene-object-id) const-int any", "doc": "Returns boss scene info based on the info type.\n\tINFO_IS_SPELL: Returns true if a spell card is active.\n\tINFO_IS_LAST_SPELL： Returns true if the Last Spell is active.\n\tINFO_IS_DURABLE_SPELL： Returns true in the case of a survival spell.\n\tINFO_IS_LAST_STEP： Returns true when the last spell is active.\n\tINFO_TIMER： Returns the timer value in seconds.\n\tINFO_TIMERF： Returns the timer value in frames (returns -1 if unlimited).\n\tINFO_ORGTIMERF： Returns the original timer value in frames (returns -1 if unlimited).\n\tINFO_SPELL_SCORE： Returns the score of the spell card.\n\tINFO_REMAIN_STEP_COUNT： Returns the number of steps remaining in the active life phase(spell, non spell, etc).\n\tINFO_ACTIVE_STEP_LIFE_COUNT： Returns the life of the enemy for the active step.\n\tINFO_ACTIVE_STEP_TOTAL_MAX_LIFE： Returns the initial life of the enemy for the active life phase.\n\tINFO_ACTIVE_STEP_TOTAL_LIFE： Returns the total remaining life for the active life phase\n\tINFO_PLAYER_SHOOTDOWN_COUNT： Returns the amount of times the player died during the spell.\n\tINFO_PLAYER_SPELL_COUNT： Returns the amount of times the player bombed during the spell.\n\tINFO_ACTIVE_STEP_LIFE_RATE_LIST： Returns an array containing the proportion (0-1) of each step's amount of life in the active life phase." },
        { "lang": "ph3", "sig": "BossScene::ObjEnemyBossScene_SetSpellTimer(obj, time)", "type": "int-(boss-scene-object-id) real void", "doc": "Sets the timer." },
        { "lang": "ph3", "sig": "BossScene::ObjEnemyBossScene_StartSpell(obj)", "type": "int-(boss-scene-object-id) void", "doc": "Starts the boss spell card." },

        // Shot Object functions

        { "lang": "ph3", "sig": "Shot::ObjShot_Create(objType)", "type": "const-int int-(shot-object-id)", "doc": "Creates a Shot object and returns its ID. Object types are:\n\tOBJ_SHOT: generic bullet\n\tOBJ_LOOSE_LASER: loose laser\n\tOBJ_STRAIGHT_LASER: straight laser\n\tOBJ_CURVE_LASER: curved laser\nIn order to draw and fire the shot object and have it listed as an existing bullet, you have to register it using ObjShot_Regist." },
        { "lang": "ph3", "sig": "Shot::ObjShot_Regist(obj)", "type": "int-(shot-object-id) void", "doc": "Activates the shot object, which will now be fired." },
        { "lang": "ph3", "sig": "Shot::ObjShot_SetAutoDelete(obj, enable)", "type": "int-(shot-object-id) bool void", "doc": "Enables or disables auto-deletion of the shot object when outside of the screen boundaries. Defaults to true." },
        { "lang": "ph3", "sig": "Shot::ObjShot_FadeDelete(obj)", "type": "int-(shot-object-id) void", "doc": "Fades out the shot object and deletes it." },
        { "lang": "ph3", "sig": "Shot::ObjShot_SetDeleteFrame(obj, frame)", "type": "int-(shot-object-id) int void", "doc": "Deletes the shot object after the specified number of frames." },
        { "lang": "ph3", "sig": "Shot::ObjShot_SetDelay(obj, frames)", "type": "int-(shot-object-id) int void", "doc": "Delays the shot object, firing it after the specified number of frames.\nBullets will glow to announce delay; lasers will be shown very thin." },
        { "lang": "ph3", "sig": "Shot::ObjShot_SetSpellResist(obj, enable)", "type": "int-(shot-object-id) bool void", "doc": "When set to true, the shot object will not be deleted by the player's bomb. Defaults to false." },
        { "lang": "ph3", "sig": "Shot::ObjShot_SetGraphic(obj, graphic)", "type": "int-(shot-object-id) const-int void", "doc": "Gives the shot object the specified graphic." },
        { "lang": "ph3", "sig": "Shot::ObjShot_SetSourceBlendType(obj, blendType)", "type": "int-(shot-object-id) const-int void", "doc": "Gives the shot object's delay graphic the specified blend type. Options are:\n\tBLEND_ALPHA: Alpha blend\n\tBLEND_ADD_RGB: Additive blend\n\tBLEND_ADD_ARGB: Additive blend with alpha channel\n\tBLEND_MULTIPLY: Multiplicative blend\n\tBLEND_SUBTRACT: Subtractive blend\n\tBLEND_INV_DESTRGB: Inverting blend" },
        { "lang": "ph3", "sig": "Shot::ObjShot_SetDamage(obj, damage)", "type": "int-(shot-object-id) real void", "doc": "Sets the damage of the specified shot object. For player shots only." },
        { "lang": "ph3", "sig": "Shot::ObjShot_SetPenetration(obj, penetration)", "type": "int-(shot-object-id) int void", "doc": "Sets the penetration of the shot object.\nThe shot object can hit enemies as many times as the penetration value before being deleted.\nFor player shots only." },
        { "lang": "ph3", "sig": "Shot::ObjShot_SetEraseShot(obj, enable)", "type": "int-(shot-object-id) bool void", "doc": "Enables/disables the ability to erase enemy shots when the specified shot object comes into contact with it. \nEach time a shot is erased, the penetration of the shot object will go down by 1.\nFor player shots only." },
        { "lang": "ph3", "sig": "Shot::ObjShot_SetSpellFactor(obj, enable)", "type": "int-(shot-object-id) bool void", "doc": "Sets whether or not to use the spell damage factor for the shot object. For player shots only." },
        { "lang": "ph3", "sig": "Shot::ObjShot_ToItem(obj)", "type": "int-(shot-object-id) void", "doc": "Turns the bullet into an item." },
        // Removed "ObjShot_AddShotA1" and "ObjShot_AddShotA2"
        { "lang": "ph3", "sig": "Shot::ObjShot_SetIntersectionCircleA1(obj, radius)", "type": "int-(shot-object-id) real void", "doc": "Creates a hitbox of specified radius for collision detection of the shot object.\nIn order to maintain the hitbox, it must be set every frame.\nThere can be multiple hitboxes set for one shot object." },
        { "lang": "ph3", "sig": "Shot::ObjShot_SetIntersectionCircleA2(obj, x, y, radius)", "type": "int-(shot-object-id) real real real void", "doc": "Creates a hitbox of specified radius for collision detection of the shot object.\nIn order to maintain the hitbox, it must be set every frame.\nThere can be multiple hitboxes set for one shot object." },
        { "lang": "ph3", "sig": "Shot::ObjShot_SetIntersectionLine(obj, x1, y1, x2, y2, width)", "type": "int-(shot-object-id) real real real real real void", "doc": "Creates a line segment hitbox between the specified coordinates for collision detection of the shot object.\nIn order to maintain the hitbox, it must be set every frame.\nThere can be multiple hitboxes set for one shot object." },
        { "lang": "ph3", "sig": "Shot::ObjShot_SetIntersectionEnable(obj, enable)", "type": "int-(shot-object-id) bool void", "doc": "Sets whether collision detection of the shot object will be checked.\nIf set to false, the shot object will have no collision detection." },
        { "lang": "ph3", "sig": "Shot::ObjShot_SetItemChange(obj, enable)", "type": "int-(shot-object-id) bool void", "doc": "Sets whether the shot object will turn into an item when deleted.\nIf set to false, the shot object will not turn into an item." },
        { "lang": "ph3", "sig": "Shot::ObjShot_IsSpellResist(obj)", "type": "int-(shot-object-id) bool", "doc": "Returns whether the shot object can be deleted by a player bomb.\nShot object bomb resistance can be set with ObjShot_SetSpellResist." },
        { "lang": "ph3", "sig": "Shot::ObjShot_GetImageID(obj)", "type": "int-(shot-object-id) const-int", "doc": "Returns the graphic ID of the shot object." },
        { "lang": "ph3", "sig": "Shot::ObjLaser_SetLength(obj, length)", "type": "int-(shot-object-id) real void", "doc": "Sets the length of the laser object." },
        { "lang": "ph3", "sig": "Shot::ObjLaser_SetRenderWidth(obj, width)", "type": "int-(shot-object-id) real void", "doc": "Sets the visible width of the laser object (not the same as the laser object's collision width). " },
        { "lang": "ph3", "sig": "Shot::ObjLaser_SetIntersectionWidth(obj, width)", "type": "int-(shot-object-id) real void", "doc": "Sets the collision width of the laser object.\nThis can be set to be larger than the laser object's render width, so take caution." },
        { "lang": "ph3", "sig": "Shot::ObjLaser_SetGrazeInvalidFrame(obj, frames)", "type": "int-(shot-object-id) int void", "doc": "Specify the number of frames after a graze where graze is not counted.\nIf you specify 0, the laser object can be grazed only once.\nThe default value is 20 frames (3 graze/second)." },
        { "lang": "ph3", "sig": "Shot::ObjLaser_SetInvalidLength(obj, startLength, endLength)", "type": "int-(shot-object-id) real real void", "doc": "Sets the portion of the laser object where there is no collision, in relation to the base and the tip of the laser.\nBy default, the values are 10 (10%)." },
        { "lang": "ph3", "sig": "Shot::ObjLaser_GetLength(obj)", "type": "int-(shot-object-id) float", "doc": "Returns the length of the laser object." },
