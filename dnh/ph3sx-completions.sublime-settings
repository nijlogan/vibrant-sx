        // Rotation Math functions
        
        { "lang": "ph3sx", "sig": "Math::Rotate2D(x, y, angle)", "type": "real real real float[2]", "doc": "Rotates the given (x, y) point around the origin (0, 0).\nDirect formula is:\nx = x * cos(angle) - y * sin(angle)\ny = x * sin(angle) + y * cos(angle)" },
        { "lang": "ph3sx", "sig": "Math::Rotate2D(x, y, angle, originX, originY)", "type": "real real real real real float[2]", "doc": "Rotates the given (x, y) point around the given origin.\nDirect formula is:\n_x = x - ox\n_y = y - oy\nx = ox + (_x * cos(angle) - _y * sin(angle))\ny = oy + (_x * sin(angle) + _y * cos(angle))" },
        { "lang": "ph3sx", "sig": "Math::Rotate3D(x, y, z, angleX, angleY, angleZ)", "type": "real real real real real real float[3]", "doc": "Rotates the given (x, y, z) point around the origin (0, 0) with the given Euler angles." },
